# Copy this file to `backend/.env` and fill in real values. Never commit `.env`.

# ─── AI (Lynx chat) ─────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Remote file uploads ────────────────────────────────────────────────────
# Bearer token + org id are forwarded per-request from /onboarding/start
# (HRMS handoff). The backend refuses to upload without them — there is no
# fallback. Only the URL itself lives here.
ONBOARDING_UPLOAD_URL=https://alfabackend.inkapps.io/api/MoneyTransfers/uploadFile
ONBOARDING_UPLOAD_TIMEOUT=60

# ─── HRMS sync (called from POST /onboarding/finalize) ──────────────────────
# Set this to the HRMS endpoint that ingests the final onboarding payload.
# Leave empty to skip server-side sync — /finalize will then return
# `synced: false` and the SPA will need to push the payload itself.
HRMS_SYNC_URL=
HRMS_SYNC_TIMEOUT=60
